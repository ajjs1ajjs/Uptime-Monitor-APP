# Application Settings
APP_NAME=Uptime Monitor
APP_VERSION=2.0.0
DEBUG=False

# Server Settings
PORT=8080
HOST=auto  # Use 'auto' to detect current IP, or specify IP (e.g., 0.0.0.0, 127.0.0.1, 192.168.1.100)

# Database Settings
DB_PATH=sites.db

# Monitoring Settings
CHECK_INTERVAL=60
NOTIFICATION_COOLDOWN=300

# Authentication
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin
SESSION_EXPIRY_DAYS=7

# Notification Settings
TELEGRAM_ENABLED=False
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

TEAMS_ENABLED=False
TEAMS_WEBHOOK_URL=

DISCORD_ENABLED=False
DISCORD_WEBHOOK_URL=

SLACK_ENABLED=False
SLACK_WEBHOOK_URL=

EMAIL_ENABLED=False
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=

SMS_ENABLED=False
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=
SMS_TO_NUMBER=

# SSL Certificate Settings
SSL_CHECK_ENABLED=True
SSL_NOTIFICATION_DAYS=7
SSL_CRITICAL_DAYS=3
SSL_WARNING_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=uptime_monitor.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Security
SECRET_KEY=your-secret-key-here
